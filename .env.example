CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
# Web Analytics → Manage site → JS snippet token (Workers need manual beacon)
CF_WEB_ANALYTICS_TOKEN=
# Brevo → SMTP & API → API keys (npm run brevo:verify / brevo:apply-secret)
BREVO_API_KEY=
# UptimeRobot → My Settings → API (optional, for npm run uptimerobot:setup)
UPTIMEROBOT_API_KEY=
# Cloudflare worker error alerts (optional, for npm run alerts:configure)
ALERT_EMAIL=
# Optional override for scripts/setup-hestia-mail-dns.mjs
# MAIL_SERVER_IP=2.25.147.42
